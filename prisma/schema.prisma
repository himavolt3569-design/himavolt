generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users (synced from Clerk) ─────────────────────────────────────

model User {
  id        String   @id
  email     String   @unique
  name      String
  username  String?  @unique
  phone     String?
  imageUrl  String?
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedRestaurants Restaurant[]
  staffMemberships StaffMember[]
  orders           Order[]
  reviews          Review[]
  fcmTokens        FCMToken[]
  auditLogs        AuditLog[]
  menuItemRatings  MenuItemRating[]
  favourites       Favourite[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  OWNER
  ADMIN
}

// ─── Restaurants ───────────────────────────────────────────────────

model Restaurant {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  restaurantCode String?        @unique // Added for staff login (e.g. HH-1A2B)
  phone          String
  countryCode    String         @default("+977")
  type           RestaurantType
  address        String
  city           String         @default("Kathmandu")
  imageUrl       String?
  coverUrl       String?
  isActive       Boolean        @default(true)
  tableCount     Int            @default(8)
  openingTime    String         @default("09:00")
  closingTime    String         @default("23:00")
  rating         Float          @default(0)
  totalOrders    Int            @default(0)
  roomCount      Int            @default(0)   // for GUEST_HOUSE, HOTEL, RESORT

  // WiFi details (shown on menu page)
  wifiName       String?
  wifiPassword   String?

  // Currency & Tax config
  currency             String  @default("NPR") // NPR, INR, USD
  taxRate              Float   @default(13)   // percentage, e.g. 13 = 13%
  taxEnabled           Boolean @default(true)
  serviceChargeRate    Float   @default(10)   // percentage, e.g. 10 = 10%
  serviceChargeEnabled Boolean @default(true)

  // Prepaid mode
  prepaidEnabled Boolean @default(false) // if true, customers must pay before food processing begins
  counterPayEnabled Boolean @default(true) // counter pay available for all types
  directPayEnabled  Boolean @default(false) // direct bank/wallet pay

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  staff          StaffMember[]
  categories     MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  reviews        Review[]
  chatRooms      ChatRoom[]
  inventory      InventoryItem[]
  stories        Story[]
  deliveryZones  DeliveryZone[]
  auditLogs      AuditLog[]
  paymentQRs     PaymentQR[]
  paymentConfig  PaymentConfig?
  heroSlides     HeroSlide[]
  tableSessions  TableSession[]
  favourites     Favourite[]
  guestCheckIns  GuestCheckIn[]
  media          Media[]
  rooms          Room[]
  roomBookings   RoomBooking[]
  coupons        Coupon[]
  prepaidTokens  PrepaidToken[]

  @@index([ownerId])
  @@index([slug])
  @@map("restaurants")
}

// ─── Inventory / Stock ─────────────────────────────────────────────

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  unit        String   @default("kg") // kg, litre, pcs, packs, etc.
  quantity    Float    @default(0)
  minStock    Float    @default(5) // alert threshold
  costPerUnit Float    @default(0)
  category    String   @default("General") // Vegetables, Spices, Meat, Drinks, etc.
  notes       String?
  imageUrl    String?  // optional product photo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Drink-specific fields
  isDrink       Boolean @default(false)
  drinkCategory String? // "Soft Drinks", "Hard Drinks", "Alcohol"
  sellingPrice  Float?  // price when sold as menu item

  // Stock-to-menu link: should this item appear on the customer menu?
  showOnMenu    Boolean @default(false)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menuItems MenuItemIngredient[]

  @@index([restaurantId])
  @@index([restaurantId, isDrink])
  @@map("inventory_items")
}

// ─── Payment QR Images ───────────────────────────────────────────

model PaymentQR {
  id        String   @id @default(cuid())
  label     String // e.g. "eSewa", "Khalti", "Fonepay", "Bank QR"
  imageUrl  String // uploaded QR image URL
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("payment_qrs")
}

// ─── Per-Restaurant Payment Configuration ────────────────────────

model PaymentConfig {
  id String @id @default(cuid())

  // Which payment methods are enabled
  cashEnabled   Boolean @default(true)
  esewaEnabled  Boolean @default(false)
  khaltiEnabled Boolean @default(false)
  bankEnabled   Boolean @default(false)

  // eSewa credentials (encrypted)
  esewaMerchantCode String?
  esewaSecretKey    String?

  // Khalti credentials (encrypted)
  khaltiSecretKey String?

  // Bank transfer details
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankBranch        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("payment_configs")
}

enum RestaurantType {
  FAST_FOOD
  RESORT
  HOTEL
  BAKERY
  CLOUD_KITCHEN
  BAR
  CAFE
  RESTAURANT
  MO_MO_SHOP
  TANDOORI
  GUEST_HOUSE
}

// ─── Staff ─────────────────────────────────────────────────────────

model StaffMember {
  id        String    @id @default(cuid())
  pin       String
  role      StaffRole
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  attendance StaffAttendance[]
  stories    Story[]
  media      Media[]

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("staff_members")
}

model StaffAttendance {
  id       String    @id @default(cuid())
  date     DateTime  @db.Date
  checkIn  DateTime
  checkOut DateTime?
  status   String    @default("PRESENT") // PRESENT, LATE, etc.

  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId])
  @@map("staff_attendance")
}

enum StaffRole {
  SUPER_ADMIN
  MANAGER
  CHEF
  WAITER
  CASHIER
}

// ─── Menu ──────────────────────────────────────────────────────────

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String
  icon      String?  // emoji or icon name
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  parentId String?
  parent   MenuCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuCategory[] @relation("CategoryHierarchy")

  items MenuItem[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@index([parentId])
  @@map("menu_categories")
}

model MenuItem {
  id             String   @id @default(cuid())
  name           String
  description    String
  price          Float
  imageUrl       String?
  rating         Float    @default(0)
  prepTime       String   @default("15-20 min")
  isVeg          Boolean  @default(false)
  hasEgg         Boolean  @default(false)
  hasOnionGarlic Boolean  @default(true)
  isAvailable    Boolean  @default(true)
  badge          String?
  tags           String[] @default([])
  sortOrder      Int      @default(0)
  discount       Float    @default(0) // percentage off (e.g. 20 = 20% off)
  discountLabel  String? // display text e.g. "FLAT Rs.100 OFF"
  isFeatured     Boolean  @default(false) // starred/highlighted by restaurant
  spiceLevel     Int      @default(0) // 0=none, 1=mild, 2=medium, 3=hot, 4=extra-hot
  calories       Int?     // kcal per serving
  allergens      String[] @default([]) // e.g. ["gluten","dairy","nuts"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Drinks tracking
  isDrink       Boolean  @default(false)
  drinkCategory String?  // "COLD" | "HOT" | "ALCOHOL"
  stockEnabled  Boolean  @default(false) // track stock for this item
  stockQuantity Float    @default(0)     // current stock count

  offerExpiresAt DateTime?
  offerStartedAt DateTime?

  sizes       MenuItemSize[]
  addOns      MenuItemAddOn[]
  orderItems  OrderItem[]
  ratings     MenuItemRating[]
  heroSlides  HeroSlide[]
  ingredients MenuItemIngredient[]

  @@index([restaurantId])
  @@index([categoryId])
  @@map("menu_items")
}

model MenuItemSize {
  id       String @id @default(cuid())
  label    String
  grams    String
  priceAdd Float  @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("menu_item_sizes")
}

model MenuItemAddOn {
  id    String @id @default(cuid())
  name  String
  price Float

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("menu_item_addons")
}

// ─── Orders ────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique
  tableNo       Int?
  roomNo        String? // guest house room number
  status        OrderStatus @default(PENDING)
  subtotal      Float
  tax           Float       @default(0)
  total         Float
  note          String?
  type          OrderType   @default(DINE_IN)
  estimatedTime Int? // estimated prep time in minutes
  acceptedAt    DateTime?
  preparingAt   DateTime?
  readyAt       DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Delivery fields
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryPhone   String?
  deliveryNote    String?
  deliveryFee     Float   @default(0)

  userId       String?
  user         User?      @relation(fields: [userId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Prepaid flow
  isPrepaid      Boolean  @default(false) // order requires payment before processing
  prepaidTokenId String?  @unique         // link to PrepaidToken once paid

  // Coupon
  couponId       String?
  couponDiscount Float    @default(0) // discount amount applied from coupon

  items          OrderItem[]
  payment        Payment?
  bill           Bill?
  chatRoom       ChatRoom?
  delivery       Delivery?
  tableSession   TableSession?
  prepaidToken   PrepaidToken? @relation(fields: [prepaidTokenId], references: [id])

  @@index([restaurantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
  REJECTED
}

enum OrderType {
  DINE_IN
  DELIVERY
  TAKEAWAY
}

model OrderItem {
  id       String  @id @default(cuid())
  name     String
  quantity Int
  price    Float
  addOns   String?

  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

// ─── Payments ───────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Float
  transactionId String?
  pidx          String? // Khalti payment idx
  refId         String? // eSewa/bank reference
  metadata      String? // JSON string for extra gateway data
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

enum PaymentMethod {
  ESEWA
  KHALTI
  BANK
  CASH
  COUNTER
  DIRECT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Bills / Invoices ───────────────────────────────────────────────

model Bill {
  id            String   @id @default(cuid())
  billNo        String   @unique
  subtotal      Float
  tax           Float
  serviceCharge Float    @default(0)
  discount      Float    @default(0)
  total         Float
  paidVia       String?
  createdAt     DateTime @default(now())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("bills")
}

// ─── FCM Tokens ─────────────────────────────────────────────────────

model FCMToken {
  id        String   @id @default(cuid())
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fcm_tokens")
}

// ─── Reviews ───────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("reviews")
}

// ─── Chat ───────────────────────────────────────────────────────────

model ChatRoom {
  id        String       @id @default(cuid())
  type      ChatRoomType @default(CUSTOMER)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  orderId      String?    @unique // null for internal/broadcast channels
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Pre-order table/room chat fields
  tableNo Int?
  roomNo  String?

  messages ChatMessage[]

  @@index([restaurantId])
  @@index([restaurantId, type])
  @@index([restaurantId, tableNo, isActive])
  @@index([restaurantId, roomNo, isActive])
  @@map("chat_rooms")
}

enum ChatRoomType {
  CUSTOMER    // per-order customer chat
  BROADCAST   // admin-to-all-staff channel
  TABLE_CHAT  // pre-order per-table chat
}

model ChatMessage {
  id         String     @id @default(cuid())
  content    String
  sender     ChatSender
  senderName String?
  createdAt  DateTime   @default(now())

  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  userId     String?

  @@index([chatRoomId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum ChatSender {
  CUSTOMER
  KITCHEN
  BILLING
  ADMIN
  MANAGER
}

// ─── Stories ────────────────────────────────────────────────────────

model Story {
  id        String    @id @default(cuid())
  type      StoryType @default(IMAGE)
  mediaUrl  String
  caption   String?
  isActive  Boolean   @default(true)
  expiresAt DateTime // auto-expire after 24h
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  staffId String?
  staff   StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([expiresAt])
  @@map("stories")
}

enum StoryType {
  IMAGE
  VIDEO
}

// ─── Audit Logs ───────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String // e.g. ORDER_CREATED, MENU_ITEM_UPDATED, STAFF_ADDED
  entity    String // e.g. Order, MenuItem, StaffMember
  entityId  String? // ID of the affected record
  detail    String? // Human-readable summary of what happened
  metadata  String? // JSON string with extra context (old/new values, etc.)
  ipAddress String?
  createdAt DateTime @default(now())

  // Who performed the action
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([restaurantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Contact Submissions ───────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}

// ─── Delivery ──────────────────────────────────────────────────────

model DeliveryDriver {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  imageUrl    String?
  vehicleType String   @default("BIKE") // BIKE, SCOOTER, CAR, BICYCLE
  vehicleNo   String?
  licenseNo   String?
  isActive    Boolean  @default(true)
  isOnline    Boolean  @default(false)
  currentLat  Float?
  currentLng  Float?
  rating      Float    @default(5.0)
  totalTrips  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries Delivery[]

  @@index([isActive, isOnline])
  @@map("delivery_drivers")
}

model Delivery {
  id            String         @id @default(cuid())
  status        DeliveryStatus @default(PENDING)
  pickupLat     Float?
  pickupLng     Float?
  dropoffLat    Float?
  dropoffLng    Float?
  distanceKm    Float?
  estimatedMins Int?
  actualMins    Int?
  fee           Float          @default(0)
  assignedAt    DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  orderId  String          @unique
  order    Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId String?
  driver   DeliveryDriver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([driverId])
  @@map("deliveries")
}

enum DeliveryStatus {
  PENDING // waiting for driver assignment
  ASSIGNED // driver assigned, heading to restaurant
  PICKED_UP // driver picked up food
  IN_TRANSIT // on the way to customer
  DELIVERED // dropped off
  CANCELLED // cancelled
}

// ─── Delivery Zones ────────────────────────────────────────────────

model DeliveryZone {
  id          String   @id @default(cuid())
  name        String // e.g. "Kathmandu Valley"
  baseFee     Float    @default(50) // base delivery charge
  perKmFee    Float    @default(15) // per km charge
  freeAbove   Float? // free delivery above this order total
  maxRadiusKm Float    @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("delivery_zones")
}

// ─── Food Ratings ────────────────────────────────────────────────

model MenuItemRating {
  id        String   @id @default(cuid())
  rating    Int // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
  @@index([menuItemId])
  @@map("menu_item_ratings")
}

// ─── Hero Slides ─────────────────────────────────────────────────

model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  subtitle  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkItemId String?
  linkItem   MenuItem? @relation(fields: [linkItemId], references: [id], onDelete: SetNull)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("hero_slides")
}

// ─── Table Sessions ──────────────────────────────────────────────

model TableSession {
  id           String    @id @default(cuid())
  tableNo      Int
  sessionToken String    @unique @default(cuid())
  isActive     Boolean   @default(true)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId      String?    @unique
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([restaurantId, tableNo, isActive])
  @@index([sessionToken])
  @@map("table_sessions")
}

// ─── Menu Item Ingredients (for stock deduction) ─────────────────

model MenuItemIngredient {
  id           String @id @default(cuid())
  quantityUsed Float // amount of this ingredient per serving

  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, inventoryItemId])
  @@map("menu_item_ingredients")
}

// ─── Favourites ─────────────────────────────────────────────────

model Favourite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@map("favourites")
}

// ─── Guest Check-In (for Guest House / Hotel / Resort) ───────────────

model GuestCheckIn {
  id          String    @id @default(cuid())
  guestName   String
  phone       String?
  email       String?
  idType      String?   // CITIZENSHIP, PASSPORT, DRIVING_LICENSE, VOTER_ID
  idNumber    String?
  idImageUrl  String?
  address     String?
  dob         String?   // date of birth (from ID)
  nationality String?   @default("Nepali")
  roomNo      String
  adults      Int       @default(1)
  children    Int       @default(0)
  checkInAt   DateTime  @default(now())
  checkOutAt  DateTime?
  notes       String?
  status      String    @default("CHECKED_IN") // CHECKED_IN, CHECKED_OUT

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, roomNo])
  @@index([status])
  @@map("guest_check_ins")
}

// ─── Media Library (staff-uploaded photos & videos) ─────────────────
model Media {
  id        String    @id @default(cuid())
  url       String
  type      StoryType @default(IMAGE) // reuses IMAGE/VIDEO enum
  caption   String?
  fileName  String?
  fileSize  Int?
  mimeType  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   StaffMember? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@map("media_library")
}

// ─── Rooms (for Hotel / Resort / Guest House) ───────────────────────

model Room {
  id          String   @id @default(cuid())
  roomNumber  String   // e.g. "101", "A-201"
  name        String?  // optional display name e.g. "Deluxe Suite"
  type        String   @default("STANDARD") // STANDARD, DELUXE, SUITE, DORMITORY
  floor       Int      @default(1)
  price       Float    @default(0)  // per night rate
  maxGuests   Int      @default(2)
  description String?
  amenities   String[] @default([]) // ["WiFi","AC","TV","Balcony"]
  imageUrls   String[] @default([]) // multiple room images
  videoUrl    String?               // optional room video
  isAvailable Boolean  @default(true)
  isActive    Boolean  @default(true) // soft delete
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  bookings RoomBooking[]

  @@unique([restaurantId, roomNumber])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable])
  @@map("rooms")
}

// ─── Room Bookings ──────────────────────────────────────────────────

model RoomBooking {
  id              String   @id @default(cuid())
  guestName       String
  guestPhone      String?
  guestEmail      String?
  guestAddress    String?
  guestIdType     String?  // CITIZENSHIP, PASSPORT, etc.
  guestIdNumber   String?
  adults          Int      @default(1)
  children        Int      @default(0)
  checkIn         DateTime
  checkOut        DateTime
  nights          Int      @default(1)
  totalPrice      Float    @default(0)
  advanceAmount   Float    @default(0)  // advance payment required
  advancePaid     Boolean  @default(false)
  status          String   @default("PENDING") // PENDING, CONFIRMED, CHECKED_IN, CHECKED_OUT, CANCELLED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  roomId       String
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Optional link to user (if customer is logged in)
  userId String?

  @@index([restaurantId])
  @@index([roomId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@map("room_bookings")
}

// ─── Coupons ────────────────────────────────────────────────────────

model Coupon {
  id          String   @id @default(cuid())
  code        String   // e.g. "WELCOME20"
  description String?
  type        String   @default("PERCENTAGE") // PERCENTAGE, FIXED
  value       Float    @default(0)   // discount value (percentage or fixed amount)
  minOrder    Float    @default(0)   // minimum order total to apply
  maxDiscount Float?                 // cap on discount amount (for percentage type)
  maxUses     Int?                   // total usage limit (null = unlimited)
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([code])
  @@map("coupons")
}

// ─── Prepaid Tokens ─────────────────────────────────────────────────

model PrepaidToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid()) // unique verification code
  status    String   @default("ACTIVE") // ACTIVE, USED, EXPIRED
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  usedAt    DateTime?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  order Order?

  @@index([restaurantId])
  @@index([token])
  @@map("prepaid_tokens")
}
